# --- core ---
ENV=development
SECRET_KEY=change-me
INTERNAL_TOKEN=change-me-gateway-secret
PUBLIC_BASE_URL=https://localhost

# --- postgres ---
POSTGRES_DB=waint
POSTGRES_USER=waint
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://waint:change-me@postgres:5432/waint

# --- redis / celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- keycloak ---
KEYCLOAK_URL=https://localhost/auth
KEYCLOAK_REALM=waint
KEYCLOAK_CLIENT_ID=waint-backend
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
OIDC_JWKS_URL=https://localhost/auth/realms/waint/protocol/openid-connect/certs

# --- ollama ---
OLLAMA_URL=http://ollama:11434
LLM_INTENT_MODEL=qwen2.5:7b-instruct
LLM_RENDER_MODEL=qwen2.5:7b-instruct
LLM_EMBED_MODEL=nomic-embed-text

# --- whatsapp gateway ---
WA_BACKEND_INBOUND_URL=http://backend:8000/api/v1/internal/wa/inbound
WA_SESSION_PATH=/data/wa-session

# --- encryption (base64 of 32 random bytes: `openssl rand -base64 32`) ---
ENCRYPTION_KEY=base64:CHANGEME0000000000000000000000000000000000000=

# --- integrations ---
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=svc@company.com
JIRA_API_TOKEN=change-me
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
